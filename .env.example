# ══════════════════════════════════════════════════════════════════
# AutoEval-C — Verified Free-Tier Environment (March 2026)
# Copy this file to .env and fill in your API keys.
#
# All providers listed:
#   ✔ Do NOT train on your data
#   ✔ Daily-refreshed free quotas (no one-time credits)
#   ✔ Support JSON mode / structured output
#   ✔ Support temperature=0.1 for deterministic output
#   ✔ Zero thinking tags — no special handling needed
#   ✔ Well-documented with stable OpenAI-compatible APIs
#
# IMPORTANT FOR JSON OUTPUT:
#   Always set temperature=0.1 in your LLM client config.
#   Always pass response_format={"type": "json_object"} where supported.
# ══════════════════════════════════════════════════════════════════

# ── PRIMARY PROVIDER SWITCH ────────────────────────────────────────
# Change this ONE line to switch the active provider.
# Slot rotation order: groq → cerebras → mistral → zhipu → cloudflare
LLM_PROVIDER=groq

# ── LLM INFERENCE SETTINGS (apply to all providers) ───────────────
LLM_TEMPERATURE=0.1              # Low = deterministic, consistent JSON
LLM_MAX_TOKENS=4096              # Enough for agent feedback responses
LLM_RESPONSE_FORMAT=json_object  # Pass as response_format in API call

# ── API KEYS ───────────────────────────────────────────────────────

# === GROQ — Slots 1–5 (Primary) ===
# JSON support:  ✔ json_object + json_schema
# Temperature:   ✔ Full support including 0.1
# Thinking tags: NONE on any model in this file
# Docs: https://console.groq.com/docs/rate-limits
GROQ_API_KEY=your_groq_api_key_here

# === CEREBRAS — Slots 6–7 (Throughput Fallback) ===
# JSON support:  ✔ json_object mode supported
# Temperature:   ✔ Full support including 0.1
# Thinking tags: NONE on llama3.1-8b and gpt-oss-120b
# Docs: https://inference-docs.cerebras.ai/support/rate-limits
CEREBRAS_API_KEY=your_cerebras_api_key_here

# === MISTRAL — Slot 8 (Best JSON Schema Compliance) ===
# JSON support:  ✔ json_object + custom json_schema on ALL models
# Temperature:   ✔ Full support including 0.1
# Thinking tags: NONE — cleanest JSON adherence of all providers
# Note: Free tier is experimentation only, not production throughput
# Docs: https://docs.mistral.ai/capabilities/structured_output
MISTRAL_API_KEY=your_mistral_api_key_here

# === ZHIPU — Slot 9 (Unlimited Free, Asia Low-Latency) ===
# JSON support:  ✔ json_object mode supported
# Temperature:   ✔ Full support including 0.1
# Thinking tags: NONE on flash models
# Docs: https://open.bigmodel.cn/dev/api
ZHIPU_API_KEY=your_zhipu_api_key_here

# === CLOUDFLARE — Slot 10 (Edge, Last Resort) ===
# JSON support:  ✔ json_schema mode via Workers AI
# Temperature:   ✔ Full support including 0.1
# Thinking tags: NONE on llama models
# Docs: https://developers.cloudflare.com/workers-ai/platform/limits/
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here


# ══════════════════════════════════════════════════════════════════
# PER-AGENT MODEL CONFIGURATION
# Default: Slot 1 — Groq kimi-k2 (60 RPM, zero thinking tags)
# ══════════════════════════════════════════════════════════════════

AGENT1_MODEL=moonshotai/kimi-k2-instruct
AGENT2_MODEL=moonshotai/kimi-k2-instruct
AGENT3_MODEL=moonshotai/kimi-k2-instruct


# ══════════════════════════════════════════════════════════════════
# SLOT REFERENCE — ALL VERIFIED MODELS
# No thinking tags. All support json_object + temperature=0.1.
# Change AGENT*_MODEL and LLM_PROVIDER to switch slots.
# ══════════════════════════════════════════════════════════════════

# ── GROQ SLOTS (Slots 1–5, same API key, independent RPM buckets) ──

# Slot 1: moonshotai/kimi-k2-instruct            (60 RPM / 1K RPD / 131K ctx)
#         → DEFAULT. Best C code eval + JSON. No thinking tags.

# Slot 2: openai/gpt-oss-120b                    (30 RPM / 1K RPD / 8K ctx)
#         → GPT-class output quality. Best for Agent 3 feedback.
#         ⚠ 8K context only — avoid for large code submissions.

# Slot 3: llama-3.3-70b-versatile                (30 RPM / 1K RPD / 128K ctx)
#         → Stable baseline. Use when Slot 1 daily quota exhausted.

# Slot 4: meta-llama/llama-4-scout-17b-16e-instruct (30 RPM / 1K RPD / 131K ctx)
#         → Best for large context (code + rubric > 32K tokens).

# Slot 5: openai/gpt-oss-20b                     (30 RPM / 1K RPD / ~8K ctx)
#         → Fastest Groq model ~1000 t/s. Good for Agent 1 extraction.

# ── CEREBRAS SLOTS (Slots 6–7, change LLM_PROVIDER=cerebras) ───────

# Slot 6: gpt-oss-120b                           (30 RPM / 1M tokens/day)
#         → Highest throughput. Speed: 1,000–3,000+ t/s (peak).
#         Note: Free-tier actual speed lower than peak benchmark.

# Slot 7: llama3.1-8b                            (30 RPM / 1M tokens/day)
#         → Fastest response time. Best for prompt iteration/testing.

# ── MISTRAL SLOT (Slot 8, change LLM_PROVIDER=mistral) ─────────────

# Slot 8a: mistral-large-latest                  (~120 RPM / 128K ctx)
#          → Strictest JSON schema compliance. Best all-round.

# Slot 8b: codestral-latest + mistral-large-latest (agent split)
#          → codestral for Agent 1+2 (code-specialized)
#          → mistral-large for Agent 3 (best feedback language quality)
#          AGENT1_MODEL=codestral-latest
#          AGENT2_MODEL=codestral-latest
#          AGENT3_MODEL=mistral-large-latest

# ── ZHIPU SLOTS (Slot 9, change LLM_PROVIDER=zhipu) ────────────────

# Slot 9a: glm-4.7-flash                         (30 QPS / no daily quota / 128K ctx)
#          → Unlimited free calls. Best for high-volume testing.

# Slot 9b: glm-4.5-flash                         (30 QPS / no daily quota / 1M ctx)
#          → Use when code + rubric context exceeds 128K tokens.

# ── CLOUDFLARE SLOT (Slot 10, change LLM_PROVIDER=cloudflare) ───────

# Slot 10: @cf/zai-org/glm-4.7-flash             (10K neurons/day, resets 00:00 UTC)
#          → Last resort when ALL other daily quotas exhausted.
#          → Use sparingly — 10K neurons/day goes fast with 3 agents.


# ══════════════════════════════════════════════════════════════════
# PROVIDERS EXCLUDED (Reasons)
# ══════════════════════════════════════════════════════════════════
# ❌ Qwen3 (any provider)  → Thinking tags require special API handling;
#                            not worth complexity for JSON-critical agents
# ❌ StepFun step-3.5-flash → Reasoning model with thinking tokens by design
# ❌ SambaNova             → Rate limits break agent workflows (community confirmed);
#                            $5 one-time credit only, not daily refresh
# ❌ Google Gemini         → Free tier data used for model training
# ❌ OpenRouter            → Only 50 RPD on free shared pool (too low)
# ❌ GitHub Models         → 50–150 req/day (insufficient for 3-agent loop)
# ❌ OpenAI                → One-time $5 credit, no daily refresh
# ❌ Anthropic             → No free public API tier at all
# ❌ Fireworks             → Paid only, no free daily refresh tier
# ❌ SiliconFlow           → Rate limits unverified; token cap unclear
# ❌ ByteDance/Doubao      → No verified daily-refresh free public API
# ❌ Baidu ERNIE           → Rate limits unverified; model names outdated
# ❌ NVIDIA NIM            → 40 RPM prototyping-only; too low for 3-agent loops


# ══════════════════════════════════════════════════════════════════
# CHROMADB
# ══════════════════════════════════════════════════════════════════
CHROMA_DB_PATH=data/chroma_storage


# ══════════════════════════════════════════════════════════════════
# RATE LIMIT HANDLING
# ══════════════════════════════════════════════════════════════════
LLM_RETRY_DELAY_SECONDS=20
LLM_MAX_RETRIES=3