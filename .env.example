# ══════════════════════════════════════════════════════════════════
# AutoEval-C / Codify.works — Environment Configuration
# Copy this file to .env and fill in your API keys.
# ══════════════════════════════════════════════════════════════════

# ── PROVIDER SWITCH ────────────────────────────────────────────────
# Change this ONE line to switch providers.
#   "groq"       → Slots 1-7  (free, 7 model buckets, primary rotation)
#   "cerebras"   → Slot 8     (free, ~1M tokens/day, volume tank)
#   "sambanova"  → Slot 9     (free, 20 RPM, emergency buffer)
#   "stepfun"    → Slot 10    (free, highest SWE-Bench 74.4%)
#   "openrouter" → Slot 11    (free, 50 RPD shared, last resort)
#   "fireworks"  → Production (paid, batch API, 500+ students)
LLM_PROVIDER=groq

# ── API KEYS (all free, no credit card) ────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
SAMBANOVA_API_KEY=your_sambanova_api_key_here
STEPFUN_API_KEY=your_stepfun_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── PER-AGENT MODELS ──────────────────────────────────────────────
# Only these 3 lines change per slot rotation.
# Default: Slot 1 (Groq — kimi-k2, 60 RPM, best coding + reasoning)
AGENT1_MODEL=moonshotai/kimi-k2-instruct
AGENT2_MODEL=moonshotai/kimi-k2-instruct
AGENT3_MODEL=moonshotai/kimi-k2-instruct

# ── GROQ SLOT OPTIONS (Slots 1-7, same API key) ──────────────────
# Slot 1: moonshotai/kimi-k2-instruct        (60 RPM — primary)
# Slot 2: qwen/qwen3-32b                     (60 RPM — instant flip)
# Slot 3: llama-3.3-70b-versatile            (30 RPM — stable baseline)
# Slot 4: openai/gpt-oss-120b               (30 RPM — strong JSON)
# Slot 5: openai/gpt-oss-20b                (30 RPM — fastest 1000 t/s)
# Slot 6: meta-llama/llama-4-scout-17b-16e-instruct  (30 RPM — 131K ctx)
# Slot 7: llama-3.1-8b-instant              (30 RPM, 14.4K RPD — format testing only)
#
# ── NON-GROQ SLOT OPTIONS (change LLM_PROVIDER too) ──────────────
# Slot 8:  LLM_PROVIDER=cerebras   MODEL=qwen-3-235b-a22b-instruct-2507
# Slot 9:  LLM_PROVIDER=sambanova  MODEL=Meta-Llama-3.3-70B-Instruct
# Slot 10: LLM_PROVIDER=stepfun    MODEL=step-3.5-flash
# Slot 11: LLM_PROVIDER=openrouter MODEL=arcee-ai/trinity-large-preview:free

# ── CHROMADB ──────────────────────────────────────────────────────
CHROMA_DB_PATH=data/chroma_storage